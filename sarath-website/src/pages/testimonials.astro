---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import Button from '../components/Button.astro';
import { testimonials } from '../data/testimonials';
---

<BaseLayout title="Testimonials" description="What colleagues and mentees say about working with Sarath Krishnan.">
  <section class="py-20 md:py-28">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <p class="section-label mb-4">Testimonials</p>
        <h1 class="text-4xl font-bold tracking-tight text-foreground md:text-5xl">
          Kind words from mentors and colleagues
        </h1>
        <p class="mt-4 text-lg text-muted-foreground">
          I've been fortunate to work with incredible colleagues, mentors and founders. Here are a few of their thoughts.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl gap-6 md:grid-cols-2">
        {testimonials.map((testimonial) => <TestimonialCard testimonial={testimonial} />)}
      </div>

      <div class="mt-16 text-center">
        <Button href="/contact" variant="primary" size="lg">Work together</Button>
      </div>
    </Container>
  </section>
</BaseLayout>
