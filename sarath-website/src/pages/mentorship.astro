---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Mentorship" description="1:1 engineering mentorship with Sarath Krishnan — career guidance, system design, and leadership coaching.">
  <section class="py-20 md:py-28">
    <Container>
      <div class="mx-auto max-w-3xl text-center">
        <p class="section-label mb-4">Mentorship</p>
        <h1 class="text-4xl font-bold tracking-tight text-foreground md:text-5xl">
          Accelerate your engineering career
        </h1>
        <p class="mt-4 text-lg text-muted-foreground">
          Structured 1:1 mentorship for engineers who want to grow — whether you're
          targeting your next promotion, building leadership skills, or navigating a
          career transition.
        </p>
      </div>
    </Container>
  </section>

  <section class="border-y border-border/50 bg-surface/30 py-20">
    <Container>
      <div class="mx-auto grid max-w-5xl gap-8 md:grid-cols-3">
        {
          [
            {
              title: 'Career Strategy',
              description:
                'Define your goals, identify gaps, and create a actionable roadmap for your next 6–12 months.',
              icon: '🎯',
            },
            {
              title: 'Technical Depth',
              description:
                'System design reviews, architecture discussions, and code review practice for senior+ roles.',
              icon: '⚡',
            },
            {
              title: 'Leadership Skills',
              description:
                'Communication, influence, feedback, and the soft skills that differentiate great engineers.',
              icon: '🚀',
            },
          ].map((offering) => (
            <div class="card card-hover p-6 text-center">
              <span class="text-3xl">{offering.icon}</span>
              <h3 class="mt-4 text-lg font-semibold text-foreground">{offering.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                {offering.description}
              </p>
            </div>
          ))
        }
      </div>
    </Container>
  </section>

  <section class="py-20">
    <Container>
      <div class="mx-auto max-w-3xl">
        <h2 class="text-2xl font-semibold tracking-tight text-foreground">How it works</h2>
        <div class="mt-8 space-y-6">
          {
            [
              {
                step: '01',
                title: 'Discovery call',
                description:
                  "A free 30-minute call to understand your goals and see if we're a good fit.",
              },
              {
                step: '02',
                title: 'Custom plan',
                description:
                  'We co-create a mentorship plan tailored to your specific objectives and timeline.',
              },
              {
                step: '03',
                title: 'Regular sessions',
                description:
                  'Bi-weekly 1:1 sessions with actionable homework and async support between meetings.',
              },
            ].map((item) => (
              <div class="flex gap-6">
                <span class="text-sm font-bold text-accent">{item.step}</span>
                <div>
                  <h3 class="font-semibold text-foreground">{item.title}</h3>
                  <p class="mt-1 text-sm text-muted-foreground">{item.description}</p>
                </div>
              </div>
            ))
          }
        </div>

        <div class="card mt-12 p-8 text-center">
          <p class="text-sm text-muted-foreground">Limited spots available each quarter</p>
          <p class="mt-2 text-3xl font-bold text-foreground">$200<span class="text-lg font-normal text-muted">/session</span></p>
          <div class="mt-6">
            <Button href="/contact" variant="primary" size="lg">Book a discovery call</Button>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
