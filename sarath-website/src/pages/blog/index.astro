---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Notes" description="Short notes on AI, systems, incentives, product, and human behaviour.">
  <section class="py-20 md:py-28">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <p class="section-label mb-4">Notes</p>
        <h1 class="text-4xl font-bold tracking-tight text-foreground md:text-5xl">
          Patterns worth paying attention to
        </h1>
        <p class="mt-4 text-lg text-muted-foreground">
          Short notes on AI, systems, incentives, product, and the messy ways people and technology interact.
A running archive of things I keep noticing.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-5xl gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => <ArticleCard post={post} />)}
      </div>
    </Container>
  </section>
</BaseLayout>
