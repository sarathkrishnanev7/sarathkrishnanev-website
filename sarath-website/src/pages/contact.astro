---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../layouts/../components/Container.astro';
import { site, socialLinks } from '../data/site';
---

<BaseLayout
  title="Contact"
  description={`Get in touch with ${site.name} for collaborations, ideas, or just to say hello.`}
>
  <!-- Success state -->
  <section id="success-page" class="hidden py-32 md:py-40">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full border border-border bg-surface text-4xl">
          ✓
        </div>

        <h1 class="mt-8 text-4xl font-bold tracking-tight text-foreground md:text-5xl">
          Thanks for reaching out.
        </h1>

        <p class="mt-4 text-lg text-muted-foreground">
          I’ll get back to you soon.
        </p>

        <div class="mt-12 space-y-4 text-sm text-muted-foreground">
          <p>
            If it’s urgent, reach out on
            <a
              href="https://www.linkedin.com/in/sarath-krishnan-ba5b8168/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-foreground underline underline-offset-4"
            >
              LinkedIn
            </a>
          </p>

          <p>
            Or email me directly at
            <a
              href="mailto:sarathkrishnanev7@gmail.com"
              class="text-foreground underline underline-offset-4"
            >
              sarathkrishnanev7@gmail.com
            </a>
          </p>
        </div>
      </div>
    </Container>
  </section>

  <!-- Contact form -->
  <section id="contact-page" class="py-20 md:py-28">
    <Container>
      <div class="mx-auto max-w-2xl text-center">
        <p class="section-label mb-4">Contact</p>

        <h1 class="text-4xl font-bold tracking-tight text-foreground md:text-5xl">
          Let’s talk
        </h1>

        <p class="mt-4 text-lg text-muted-foreground">
          Whether you have a question, an idea, or just want to say hello —
          I’d love to hear from you.
        </p>
      </div>

      <div class="mx-auto mt-16 grid max-w-4xl gap-8 lg:grid-cols-2">
        <form id="contact-form" class="card p-8">
          <input
            type="hidden"
            name="_subject"
            value="WEBSITE ALERT - New Message"
          />

          <div class="space-y-5">
            <div>
              <label
                for="name"
                class="mb-2 block text-sm font-medium text-foreground"
              >
                Name
              </label>

              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="What should I call you?"
                class="w-full rounded-lg border border-border bg-surface px-4 py-2.5 text-sm text-foreground"
              />
            </div>

            <div>
              <label
                for="email"
                class="mb-2 block text-sm font-medium text-foreground"
              >
                Email
              </label>

              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="Where can I write back?"
                class="w-full rounded-lg border border-border bg-surface px-4 py-2.5 text-sm text-foreground"
              />
            </div>

            <div>
              <label
                for="message"
                class="mb-2 block text-sm font-medium text-foreground"
              >
                Message
              </label>

              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="What’s on your mind?"
                class="w-full resize-none rounded-lg border border-border bg-surface px-4 py-2.5 text-sm text-foreground"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full rounded-lg bg-foreground px-5 py-2.5 text-sm font-medium text-background"
            >
              Say hello
            </button>
          </div>
        </form>

        <div class="space-y-6">
          <div class="card p-6">
            <h3 class="font-semibold text-foreground">Email</h3>
            <a
              href={`mailto:${site.email}`}
              class="mt-2 block text-sm text-accent"
            >
              {site.email}
            </a>
          </div>

          <div class="card p-6">
            <h3 class="font-semibold text-foreground">Location</h3>
            <p class="mt-2 text-sm text-muted-foreground">{site.location}</p>
          </div>

          <div class="card p-6">
            <h3 class="font-semibold text-foreground">Social</h3>

            <ul class="mt-3 space-y-2">
              {
                socialLinks.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm text-muted-foreground"
                    >
                      {link.label} →
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form');
  const successPage = document.getElementById('success-page');
  const contactPage = document.getElementById('contact-page');

  // Browser-side query param detection
  const params = new URLSearchParams(window.location.search);

  if (params.get('success') === 'true') {
    successPage?.classList.remove('hidden');
    contactPage?.classList.add('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);

    const response = await fetch('https://formspree.io/f/xqeorzpk', {
      method: 'POST',
      body: formData,
      headers: {
        Accept: 'application/json',
      },
    });

    if (response.ok) {
      window.location.href = '/contact?success=true';
    }
  });
</script>