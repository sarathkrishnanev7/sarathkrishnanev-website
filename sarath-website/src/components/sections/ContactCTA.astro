---
import Container from '../Container.astro';
import Button from '../Button.astro';
import { site } from '../../data/site';
---

<section class="border-t border-border/50 py-16 md:py-20">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <p class="section-label mb-4">Contact</p>
      <h2 class="text-3xl font-bold tracking-tight text-foreground md:text-4xl">
        Let's connect
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground">
        Have a project in mind, want to collaborate, or just say hello? I'd love
        to hear from you.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Button href="/contact" variant="primary" size="lg">Get in touch</Button>
        <Button href={`mailto:${site.email}`} variant="secondary" size="lg">
          {site.email}
        </Button>
      </div>
    </div>
  </Container>
</section>
