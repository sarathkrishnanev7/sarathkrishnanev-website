---
import Container from '../Container.astro';
import Button from '../Button.astro';
---

<section class="relative overflow-hidden py-24 md:py-32">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(0,112,243,0.08),transparent_70%)]"
  >
  </div>
  <Container class="relative">
    <div class="mx-auto max-w-3xl text-center">
      <p class="section-label mb-6">PRODUCT STRATEGY • AI • STARTUPS</p>
      <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl md:text-6xl lg:text-7xl">
          Exploring AI,
        <br />
          human systems,
        <br />
          and the future of work.
      </h1>
     <div class="mt-8">
  <p class="mx-auto mt-4 max-w-2xl text-xl leading-relaxed text-muted-foreground">
    Hey. I'm Sarath.
  </p>

 <p class="mx-auto mt-4 max-w-2xl text-xl leading-relaxed text-muted-foreground">
  I write about <strong class="text-foreground">artificial intelligence</strong>,
  <strong class="text-foreground">startups</strong>,
  <strong class="text-foreground">product strategy</strong> and the systems that shape human behavior.
</p>

  <p class="mx-auto mt-4 max-w-2xl text-xl leading-relaxed text-muted-foreground">
    IIT Madras • IIM Lucknow • Citi • Olam • Katha Ads
  </p>
</div>

    <!-- Decorative grid -->
    <div
      class="pointer-events-none absolute inset-x-0 -bottom-px h-px bg-gradient-to-r from-transparent via-border to-transparent"
    >
    </div>
  </Container>
</section>
