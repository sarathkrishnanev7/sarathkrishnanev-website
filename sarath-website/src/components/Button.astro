---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  external?: boolean;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  class: className = '',
  external = false,
} = Astro.props;

const variants = {
  primary:
    'bg-foreground text-background hover:bg-foreground/90 shadow-[0_0_0_1px_rgba(255,255,255,0.1)]',
  secondary:
    'border border-border bg-surface-elevated/50 text-foreground hover:border-border-hover hover:bg-surface-elevated',
  ghost: 'text-muted-foreground hover:text-foreground hover:bg-surface-elevated/50',
};

const sizes = {
  sm: 'px-3 py-1.5 text-sm',
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-6 py-3 text-base',
};
---

<a
  href={href}
  class:list={[
    'inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-all duration-200',
    variants[variant],
    sizes[size],
    className,
  ]}
  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
>
  <slot />
</a>
